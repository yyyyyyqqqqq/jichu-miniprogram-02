page {
  min-height: 100%;
  background: #f5f7f6;
  color: #1f2a25;
  font-size: 28rpx;
}

view,
text,
input,
button,
scroll-view {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(160rpx + env(safe-area-inset-bottom));
}

.page-shell--plain {
  min-height: 100vh;
  padding: 28rpx;
}

.surface-card {
  background: #ffffff;
  border: 1rpx solid #edf1ef;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 32rpx rgba(28, 61, 45, 0.06);
}

.page-title {
  color: #15221c;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #78827d;
  font-size: 25rpx;
  line-height: 1.6;
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-button {
  background: #16a36a;
  color: #ffffff;
}

.secondary-button {
  background: #eaf7f1;
  color: #13865a;
}

.muted-text {
  color: #87918c;
}

.placeholder-page {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 42rpx;
  text-align: center;
}

.placeholder-mark {
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  border-radius: 32rpx;
  background: #eaf7f1;
  color: #16a36a;
  font-size: 46rpx;
  font-weight: 700;
}

.placeholder-title {
  color: #1f2a25;
  font-size: 34rpx;
  font-weight: 700;
}

.placeholder-description {
  max-width: 560rpx;
  margin-top: 18rpx;
  color: #7c8781;
  font-size: 26rpx;
  line-height: 1.75;
}
