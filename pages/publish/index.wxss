.publish-page {
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

.publish-header {
  padding: 8rpx 4rpx 28rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: #16a36a;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.result-notice {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #f0d9a8;
  border-radius: 20rpx;
  background: #fff8e8;
}

.result-notice__title {
  color: #936116;
  font-size: 26rpx;
  font-weight: 700;
}

.result-notice__description {
  margin-top: 8rpx;
  color: #a17737;
  font-size: 22rpx;
  line-height: 1.65;
}

.form-card {
  overflow: hidden;
  padding: 0 28rpx;
}

.form-section {
  padding: 30rpx 0;
  border-top: 1rpx solid #edf1ef;
}

.form-section--first {
  border-top: 0;
}

.section-heading,
.field-heading {
  display: flex;
  align-items: center;
}

.section-heading {
  justify-content: space-between;
}

.section-title,
.field-label {
  color: #2e3d35;
  font-size: 27rpx;
  font-weight: 700;
}

.section-meta,
.field-count {
  margin-left: auto;
  color: #98a19c;
  font-size: 21rpx;
}

.required-mark {
  margin-left: 7rpx;
  color: #ef5d42;
  font-size: 24rpx;
}

.section-tip {
  margin-top: 9rpx;
  color: #929b96;
  font-size: 21rpx;
  line-height: 1.55;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.image-item,
.choose-image {
  position: relative;
  height: 190rpx;
  margin: 0;
  border-radius: 18rpx;
}

.image-item {
  overflow: hidden;
  background: #edf3f0;
}

.selected-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(31, 42, 37, 0.72);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1;
}

.choose-image {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 2rpx dashed #cfe2d9;
  background: #f4faf7;
  color: #719080;
  font-size: 21rpx;
}

.choose-image[disabled] {
  background: #f2f4f3;
  color: #a4aba7;
}

.choose-image__plus {
  margin-bottom: 8rpx;
  color: #16a36a;
  font-size: 44rpx;
  line-height: 1;
}

.form-input,
.form-textarea {
  width: 100%;
  margin-top: 16rpx;
  border: 1rpx solid #e4ebe7;
  border-radius: 17rpx;
  background: #f8faf9;
  color: #26342d;
  font-size: 26rpx;
}

.form-input {
  height: 82rpx;
  padding: 0 22rpx;
}

.form-textarea {
  min-height: 190rpx;
  padding: 20rpx 22rpx;
  line-height: 1.7;
}

.form-input[disabled],
.form-textarea[disabled] {
  color: #78827d;
  background: #f1f4f2;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  border: 1rpx solid #e4ebe7;
  border-radius: 17rpx;
  background: #f8faf9;
}

.currency-symbol {
  flex: none;
  padding-left: 22rpx;
  color: #ef5d42;
  font-size: 32rpx;
  font-weight: 700;
}

.price-input {
  margin-top: 0;
  border: 0;
  background: transparent;
  color: #ef5d42;
  font-size: 32rpx;
  font-weight: 700;
}

.option-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.option-grid--condition {
  grid-template-columns: repeat(2, 1fr);
}

.option-chip {
  min-height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 14rpx;
  border: 1rpx solid #e4ebe7;
  border-radius: 16rpx;
  background: #f8faf9;
  color: #6f7b74;
  font-size: 23rpx;
  text-align: center;
}

.option-chip--active {
  border-color: #8ed1b3;
  background: #e8f7f0;
  color: #13865a;
  font-weight: 700;
}

.safety-note {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #e6eadf;
  border-radius: 20rpx;
  background: #fbfcf5;
}

.safety-mark {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 17rpx;
  background: #edf3d8;
  color: #718332;
  font-size: 22rpx;
  font-weight: 700;
}

.safety-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-left: 16rpx;
}

.safety-title {
  color: #4a5734;
  font-size: 24rpx;
  font-weight: 700;
}

.safety-description {
  margin-top: 6rpx;
  color: #7a8466;
  font-size: 21rpx;
}

.submit-panel {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 14rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8eeeb;
  background: rgba(255, 255, 255, 0.98);
}

.submit-stage {
  display: block;
  margin-bottom: 10rpx;
  color: #77837c;
  font-size: 21rpx;
  text-align: center;
}

.submit-button {
  width: 100%;
  margin: 0;
}

.submit-button[disabled] {
  background: #a9d8c2;
  color: #ffffff;
}

.login-placeholder {
  margin-top: 100rpx;
}

.login-button {
  width: 300rpx;
  margin-top: 36rpx;
}
