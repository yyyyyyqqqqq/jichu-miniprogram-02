.detail-page {
  padding-bottom: calc(158rpx + env(safe-area-inset-bottom));
}

.detail-error {
  min-height: 75vh;
  display: flex;
  align-items: center;
}

.detail-error-card {
  width: 100%;
  padding-bottom: 34rpx;
}

.detail-home-button {
  width: 260rpx;
  height: 70rpx;
  margin: -12rpx auto 0;
  border-radius: 999rpx;
  background: #f1f5f3;
  color: #66716b;
  font-size: 24rpx;
  line-height: 70rpx;
}

.detail-cover {
  position: relative;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: -28rpx -28rpx 24rpx;
  background: #e8f6ef;
}

.detail-cover--blue {
  background: #e7f0fb;
}

.detail-cover--sand {
  background: #f4eee2;
}

.detail-cover--rose {
  background: #f8e9eb;
}

.detail-cover--lime {
  background: #edf5df;
}

.detail-cover--violet {
  background: #eeeafa;
}

.detail-cover--cyan {
  background: #e4f4f3;
}

.detail-cover--orange {
  background: #faeddf;
}

.detail-cover--indigo {
  background: #e8eafa;
}

.detail-cover--amber {
  background: #f8f0da;
}

.detail-cover--coral {
  background: #f8e8e2;
}

.detail-cover--sage {
  background: #e8f0e6;
}

.detail-cover--slate {
  background: #e8edf0;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.detail-cover-label {
  color: rgba(28, 74, 53, 0.55);
  font-size: 66rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
}

.detail-status,
.detail-condition {
  position: absolute;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  font-size: 23rpx;
}

.detail-status {
  top: 28rpx;
  right: 28rpx;
  color: #15865b;
  font-weight: 700;
}

.detail-status--reserved {
  background: rgba(255, 247, 226, 0.94);
  color: #b97513;
}

.detail-status--sold {
  background: rgba(238, 241, 239, 0.94);
  color: #68736d;
}

.detail-condition {
  right: 28rpx;
  bottom: 28rpx;
  color: #34483e;
}

.status-notice {
  margin-bottom: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.status-notice--reserved {
  border: 1rpx solid #f0d9a8;
  background: #fff8e8;
  color: #9a681d;
}

.status-notice--sold {
  border: 1rpx solid #dfe4e1;
  background: #f1f4f2;
  color: #69736e;
}

.detail-main,
.detail-section,
.seller-card {
  padding: 28rpx;
}

.detail-section,
.seller-card,
.safety-card {
  margin-top: 22rpx;
}

.detail-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-price-group {
  min-width: 0;
  display: flex;
  align-items: baseline;
  flex: 1;
}

.price-value {
  color: #ef5d42;
  font-size: 52rpx;
  font-weight: 760;
  white-space: nowrap;
}

.price-value--free {
  color: #16a36a;
  font-size: 40rpx;
}

.original-price {
  margin-left: 14rpx;
  color: #a0a8a4;
  font-size: 23rpx;
  text-decoration: line-through;
  white-space: nowrap;
}

.category-name {
  flex: none;
  margin-left: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf7f1;
  color: #13865a;
  font-size: 22rpx;
}

.detail-title {
  margin-top: 16rpx;
  color: #1f2a25;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.45;
  word-break: break-all;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag-item {
  padding: 7rpx 14rpx;
  border-radius: 9rpx;
  background: #f1f5f3;
  color: #66716b;
  font-size: 22rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf1ef;
  color: #929b96;
  font-size: 22rpx;
}

.stats-dot {
  width: 6rpx;
  height: 6rpx;
  margin: 0 18rpx;
  border-radius: 50%;
  background: #c2c9c5;
}

.section-title {
  color: #2e3d35;
  font-size: 29rpx;
  font-weight: 700;
}

.description-text {
  margin-top: 18rpx;
  color: #65716b;
  font-size: 26rpx;
  line-height: 1.8;
  word-break: break-all;
}

.info-list {
  margin-top: 10rpx;
}

.info-row {
  min-height: 86rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #edf1ef;
}

.info-row--last {
  border-bottom: 0;
}

.info-label {
  width: 150rpx;
  flex: none;
  color: #8d9792;
  font-size: 24rpx;
}

.info-value {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #405047;
  font-size: 25rpx;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value--wrap {
  white-space: normal;
  word-break: break-all;
}

.seller-card {
  display: flex;
  align-items: center;
}

.seller-avatar {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 28rpx;
  background: #dff2e9;
  color: #13865a;
  font-size: 35rpx;
  font-weight: 700;
}

.seller-info {
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  margin-left: 20rpx;
}

.seller-name-row {
  display: flex;
  align-items: center;
}

.seller-name {
  overflow: hidden;
  color: #2e3d35;
  font-size: 27rpx;
  font-weight: 650;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.verified-badge {
  flex: none;
  margin-left: 12rpx;
  padding: 4rpx 9rpx;
  border-radius: 7rpx;
  background: #eaf7f1;
  color: #13865a;
  font-size: 18rpx;
}

.seller-note {
  margin-top: 8rpx;
  color: #929b96;
  font-size: 22rpx;
}

.seller-link {
  display: flex;
  align-items: center;
  flex: none;
  margin-left: 16rpx;
  color: #16a36a;
  font-size: 22rpx;
}

.seller-arrow {
  margin-left: 7rpx;
  font-size: 34rpx;
}

.safety-card {
  display: flex;
  padding: 24rpx;
  border: 1rpx solid #e6eadf;
  border-radius: 22rpx;
  background: #fbfcf5;
}

.safety-icon {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 18rpx;
  background: #edf3d8;
  color: #718332;
  font-size: 23rpx;
  font-weight: 700;
}

.safety-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.safety-title {
  color: #4a5734;
  font-size: 25rpx;
  font-weight: 650;
}

.safety-description {
  margin-top: 8rpx;
  color: #7a8466;
  font-size: 22rpx;
  line-height: 1.65;
}

.detail-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8eeeb;
  background: rgba(255, 255, 255, 0.98);
}

.action-button {
  width: auto;
  flex: 1;
  margin: 0;
}

.action-button--main {
  flex: 1.7;
}

.action-button--disabled,
.action-button[disabled] {
  background: #dfe4e1;
  color: #8b9490;
}
