<view class="page-shell">
  <view class="surface-card profile-card">
    <view class="avatar-placeholder">即</view>
    <view class="profile-copy">
      <text class="profile-name">{{isLoggedIn ? '校园用户' : '暂未登录'}}</text>
      <text class="profile-note">{{isLoggedIn ? '欢迎回来' : '登录功能将在后续阶段接入'}}</text>
    </view>
    <button wx:if="{{!isLoggedIn}}" class="login-button" bindtap="goLogin">登录</button>
  </view>

  <view class="surface-card menu-card">
    <view class="menu-item" bindtap="goMyProducts">
      <view class="menu-icon">发</view>
      <text class="menu-label">我的发布</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <view class="menu-icon">藏</view>
      <text class="menu-label">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item menu-item--last" bindtap="showAbout">
      <view class="menu-icon">介</view>
      <text class="menu-label">关于项目</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="safety-note">校内线下面交 · 不涉及在线支付</view>
</view>
