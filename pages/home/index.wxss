.home-page {
  padding-top: 34rpx;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-copy {
  min-width: 0;
}

.eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: #16a36a;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.campus-badge {
  min-width: 100rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  margin-left: 24rpx;
  border: 1rpx solid #cce9dc;
  border-radius: 18rpx;
  background: #eaf7f1;
  color: #13865a;
  font-size: 23rpx;
  font-weight: 650;
}

.campus-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #16a36a;
}

.scene-tip {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #dcebe4;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #f0faf5, #ffffff);
}

.scene-icon {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 18rpx;
  background: #16a36a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.scene-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  margin-left: 18rpx;
}

.scene-title {
  color: #32423a;
  font-size: 25rpx;
  font-weight: 650;
}

.scene-description {
  margin-top: 7rpx;
  color: #87918c;
  font-size: 21rpx;
}

.search-section {
  margin-top: 28rpx;
}

.category-section {
  margin-top: 24rpx;
}

.sort-section {
  margin-top: 26rpx;
  padding: 22rpx 22rpx 18rpx;
  border: 1rpx solid #e8eeeb;
  border-radius: 22rpx;
  background: #ffffff;
}

.sort-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sort-title {
  color: #425048;
  font-size: 23rpx;
  font-weight: 650;
}

.refresh-label {
  color: #16a36a;
  font-size: 21rpx;
}

.sort-scroll {
  width: 100%;
  white-space: nowrap;
}

.sort-row {
  display: inline-flex;
  gap: 12rpx;
}

.sort-item {
  min-width: 104rpx;
  height: 52rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f3f6f4;
  color: #748079;
  font-size: 22rpx;
}

.sort-item--active {
  background: #e3f5ec;
  color: #13865a;
  font-weight: 650;
}

.list-heading {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 2rpx 18rpx;
}

.list-heading-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.list-title {
  color: #26342d;
  font-size: 30rpx;
  font-weight: 700;
}

.query-summary {
  overflow: hidden;
  max-width: 560rpx;
  margin-top: 7rpx;
  color: #8a948f;
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.query-loading {
  flex: none;
  margin-left: 18rpx;
  padding: 8rpx 15rpx;
  border-radius: 999rpx;
  background: #eaf7f1;
  color: #13865a;
  font-size: 20rpx;
}

.load-more-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 10rpx;
  color: #929b96;
  font-size: 22rpx;
}

.load-more-retry {
  height: 58rpx;
  margin-top: 14rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #eaf7f1;
  color: #13865a;
  font-size: 22rpx;
  line-height: 58rpx;
}

.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 8rpx;
  color: #a0a8a4;
  font-size: 22rpx;
}

.list-end-line {
  width: 72rpx;
  height: 1rpx;
  margin: 0 18rpx;
  background: #dde3e0;
}
