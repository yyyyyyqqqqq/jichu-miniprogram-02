.message-header {
  padding: 10rpx 2rpx 30rpx;
}

.message-empty {
  margin-top: 8rpx;
}

.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.conversation-card {
  display: flex;
  padding: 24rpx;
}

.conversation-avatar {
  width: 86rpx;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  overflow: hidden;
  border-radius: 28rpx;
  background: #e3f3eb;
  color: #14865b;
  font-size: 32rpx;
  font-weight: 700;
}

.conversation-avatar-image {
  width: 100%;
  height: 100%;
}

.conversation-main {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.conversation-title-row,
.conversation-product-row,
.conversation-summary-row {
  display: flex;
  align-items: center;
}

.conversation-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #25332c;
  font-size: 28rpx;
  font-weight: 680;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conversation-time {
  flex: none;
  margin-left: 16rpx;
  color: #9aa39f;
  font-size: 20rpx;
}

.conversation-product-row {
  min-width: 0;
  margin-top: 13rpx;
}

.conversation-product-image {
  width: 42rpx;
  height: 42rpx;
  flex: none;
  border-radius: 10rpx;
  background: #eef3f0;
}

.conversation-product-title {
  min-width: 0;
  flex: 1;
  margin-left: 10rpx;
  overflow: hidden;
  color: #6c7771;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-status {
  flex: none;
  margin-left: 10rpx;
  padding: 4rpx 9rpx;
  border-radius: 7rpx;
  background: #eaf7f1;
  color: #14865b;
  font-size: 18rpx;
}

.product-status--reserved {
  background: #fff4dc;
  color: #a66a11;
}

.product-status--offline,
.product-status--sold,
.product-status--deleted {
  background: #eef1ef;
  color: #737d78;
}

.conversation-summary-row {
  margin-top: 12rpx;
}

.conversation-summary {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #8a948f;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread-badge {
  min-width: 34rpx;
  height: 34rpx;
  margin-left: 14rpx;
  padding: 0 9rpx;
  border-radius: 999rpx;
  background: #ef5d42;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 34rpx;
  text-align: center;
}

.load-more-error,
.list-end {
  padding: 24rpx 0 8rpx;
  color: #919b96;
  font-size: 22rpx;
  text-align: center;
}

.retry-link {
  margin-left: 14rpx;
  color: #16a36a;
}
