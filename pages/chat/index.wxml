<view class="chat-page">
  <loading-state
    wx:if="{{viewState === 'loading'}}"
    text="正在进入会话"
  />

  <view wx:elif="{{viewState === 'error'}}" class="chat-error surface-card">
    <empty-state
      title="会话暂时无法打开"
      description="{{errorMessage}}"
      action-text="重新加载"
      bind:action="retryConversation"
    />
    <button class="back-messages-button" bindtap="goMessages">返回消息</button>
  </view>

  <block wx:elif="{{viewState === 'success' && conversation}}">
    <view class="chat-header">
      <view class="other-user-row">
        <view class="chat-avatar">
          <image
            wx:if="{{conversation.otherUser.avatarUrl}}"
            class="chat-avatar-image"
            src="{{conversation.otherUser.avatarUrl}}"
            mode="aspectFill"
          />
          <text wx:else>{{conversation.otherUser.avatarText}}</text>
        </view>
        <view class="other-user-copy">
          <text class="other-user-name">{{conversation.otherUser.nickname}}</text>
          <text class="other-user-campus">{{conversation.otherUser.campus}}</text>
        </view>
      </view>

      <view class="product-card" bindtap="onProductTap">
        <image
          wx:if="{{conversation.product.coverImage}}"
          class="product-image"
          src="{{conversation.product.coverImage}}"
          mode="aspectFill"
        />
        <view class="product-copy">
          <text class="product-title">{{conversation.product.title}}</text>
          <view class="product-meta">
            <text class="product-price">{{conversation.product.priceDisplay}}</text>
            <text class="product-state product-state--{{conversation.product.status}}">
              {{conversation.product.statusText}}
            </text>
          </view>
        </view>
        <text class="product-arrow">›</text>
      </view>
    </view>

    <scroll-view
      class="message-scroll"
      scroll-y
      upper-threshold="80"
      scroll-into-view="{{scrollIntoView}}"
      bindscrolltoupper="loadEarlierMessages"
    >
      <view class="history-status">
        <loading-state
          wx:if="{{isLoadingEarlier}}"
          compact
          text="正在加载更早消息"
        />
        <view wx:elif="{{historyError}}" class="history-error">
          <text>{{historyError}}</text>
          <text class="history-retry" bindtap="retryHistory">重试</text>
        </view>
        <text wx:elif="{{!hasMore && messages.length > 0}}" class="history-end">
          已显示全部历史消息
        </text>
      </view>

      <view wx:if="{{messages.length === 0}}" class="chat-empty">
        <text class="chat-empty-title">开始聊聊这件闲置吧</text>
        <text class="chat-empty-description">请勿发送敏感信息，建议在校园公共区域面交</text>
      </view>

      <view
        wx:for="{{messages}}"
        wx:key="messageId"
        class="message-row {{item.isMine ? 'message-row--mine' : ''}}"
      >
        <view
          class="message-bubble {{item.isMine ? 'message-bubble--mine' : ''}} {{item.sendStatus === 'failed' ? 'message-bubble--failed' : ''}}"
          data-client-message-id="{{item.clientMessageId}}"
          bindtap="retryMessage"
        >
          <text class="message-content">{{item.content}}</text>
          <view class="message-meta">
            <text>{{item.createdAtText}}</text>
            <text wx:if="{{item.sendStatus === 'sending'}}" class="send-state">发送中</text>
            <text wx:elif="{{item.sendStatus === 'failed'}}" class="send-state send-state--failed">
              发送失败，点此重试
            </text>
          </view>
        </view>
      </view>
      <view id="chat-bottom" class="chat-bottom-anchor"></view>
    </scroll-view>

    <view wx:if="{{!conversation.canSend}}" class="send-disabled-notice">
      商品已删除，当前会话仅可查看历史消息
    </view>
    <view wx:else class="composer">
      <textarea
        class="composer-input"
        value="{{inputValue}}"
        maxlength="{{maxLength}}"
        auto-height
        show-confirm-bar="{{false}}"
        cursor-spacing="24"
        placeholder="输入消息"
        bindinput="onInput"
      />
      <view class="composer-side">
        <text class="input-counter">{{inputLength}}/{{maxLength}}</text>
        <button
          class="send-button"
          disabled="{{sendDisabled}}"
          bindtap="sendMessage"
        >
          {{isSending ? '发送中' : '发送'}}
        </button>
      </view>
    </view>
  </block>
</view>
