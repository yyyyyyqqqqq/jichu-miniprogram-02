.chat-page {
  min-height: 100vh;
}

.chat-error {
  margin: 28rpx;
  padding-bottom: 30rpx;
}

.back-messages-button {
  width: 240rpx;
  height: 68rpx;
  margin: -12rpx auto 0;
  border-radius: 999rpx;
  background: #f0f4f2;
  color: #64716a;
  font-size: 24rpx;
  line-height: 68rpx;
}

.chat-header {
  padding: 20rpx 28rpx 18rpx;
  border-bottom: 1rpx solid #e9eeeb;
  background: #ffffff;
}

.other-user-row {
  display: flex;
  align-items: center;
}

.chat-avatar {
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 22rpx;
  background: #e2f3eb;
  color: #14865b;
  font-size: 26rpx;
  font-weight: 700;
}

.chat-avatar-image {
  width: 100%;
  height: 100%;
}

.other-user-copy {
  display: flex;
  flex-direction: column;
  margin-left: 16rpx;
}

.other-user-name {
  color: #26342d;
  font-size: 27rpx;
  font-weight: 680;
}

.other-user-campus {
  margin-top: 5rpx;
  color: #929c97;
  font-size: 20rpx;
}

.product-card {
  display: flex;
  align-items: center;
  margin-top: 17rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f4f7f5;
}

.product-image {
  width: 74rpx;
  height: 74rpx;
  flex: none;
  border-radius: 14rpx;
  background: #e7edea;
}

.product-copy {
  min-width: 0;
  flex: 1;
  margin-left: 14rpx;
}

.product-title {
  display: block;
  overflow: hidden;
  color: #34433b;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.product-price {
  color: #ef5d42;
  font-size: 22rpx;
  font-weight: 680;
}

.product-state {
  margin-left: 12rpx;
  padding: 3rpx 8rpx;
  border-radius: 6rpx;
  background: #e6f5ee;
  color: #15865b;
  font-size: 17rpx;
}

.product-state--reserved {
  background: #fff2d7;
  color: #a66a11;
}

.product-state--offline,
.product-state--sold,
.product-state--deleted {
  background: #e9eeeb;
  color: #747e79;
}

.product-arrow {
  margin-left: 10rpx;
  color: #9aa39f;
  font-size: 34rpx;
}

.message-scroll {
  height: calc(100vh - 344rpx - env(safe-area-inset-bottom));
  padding: 0 28rpx;
}

.history-status {
  min-height: 54rpx;
  text-align: center;
}

.history-error,
.history-end {
  display: block;
  padding: 18rpx 0 8rpx;
  color: #99a29e;
  font-size: 20rpx;
}

.history-retry {
  margin-left: 12rpx;
  color: #16a36a;
}

.chat-empty {
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.chat-empty-title {
  color: #65716b;
  font-size: 26rpx;
}

.chat-empty-description {
  max-width: 500rpx;
  margin-top: 14rpx;
  color: #9aa39f;
  font-size: 21rpx;
  line-height: 1.6;
}

.message-row {
  display: flex;
  justify-content: flex-start;
  margin: 18rpx 0;
}

.message-row--mine {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 76%;
  padding: 18rpx 20rpx 12rpx;
  border-radius: 8rpx 22rpx 22rpx 22rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(27, 59, 44, 0.05);
}

.message-bubble--mine {
  border-radius: 22rpx 8rpx 22rpx 22rpx;
  background: #dff4e9;
}

.message-bubble--failed {
  border: 1rpx solid #efb0a6;
  background: #fff0ed;
}

.message-content {
  color: #25342c;
  font-size: 27rpx;
  line-height: 1.65;
  word-break: break-all;
  white-space: pre-wrap;
}

.message-meta {
  display: flex;
  justify-content: flex-end;
  margin-top: 7rpx;
  color: #9ba49f;
  font-size: 18rpx;
}

.send-state {
  margin-left: 10rpx;
}

.send-state--failed {
  color: #d95745;
}

.chat-bottom-anchor {
  height: 24rpx;
}

.composer,
.send-disabled-notice {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  border-top: 1rpx solid #e4ebe7;
  background: #ffffff;
}

.composer {
  display: flex;
  align-items: flex-end;
  padding: 16rpx 22rpx calc(16rpx + env(safe-area-inset-bottom));
}

.composer-input {
  min-height: 72rpx;
  max-height: 190rpx;
  flex: 1;
  padding: 17rpx 20rpx;
  border-radius: 20rpx;
  background: #f2f5f3;
  color: #26342d;
  font-size: 26rpx;
  line-height: 1.5;
}

.composer-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 14rpx;
}

.input-counter {
  margin-bottom: 6rpx;
  color: #a0a8a4;
  font-size: 17rpx;
}

.send-button {
  width: 126rpx;
  height: 68rpx;
  margin: 0;
  border-radius: 18rpx;
  background: #16a36a;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 68rpx;
}

.send-button[disabled] {
  background: #dce4e0;
  color: #909a95;
}

.send-disabled-notice {
  padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  color: #7d8782;
  font-size: 23rpx;
  text-align: center;
}
