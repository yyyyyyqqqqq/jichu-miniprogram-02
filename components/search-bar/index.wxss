.search-bar {
  height: 84rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border: 1rpx solid #e3e9e6;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 63, 48, 0.04);
}

.search-icon {
  position: relative;
  width: 26rpx;
  height: 26rpx;
  flex: none;
  margin-right: 18rpx;
  border: 4rpx solid #7f8a84;
  border-radius: 50%;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -12rpx;
  bottom: -8rpx;
  width: 14rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #7f8a84;
  transform: rotate(45deg);
}

.search-input {
  min-width: 0;
  height: 100%;
  flex: 1;
  color: #25312b;
  font-size: 27rpx;
}

.search-placeholder {
  color: #a2aaa6;
}

.clear-button {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #eef2f0;
  color: #7b8580;
  font-size: 32rpx;
  line-height: 1;
}
