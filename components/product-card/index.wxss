.product-card {
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 1rpx solid #edf1ef;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 32rpx rgba(28, 61, 45, 0.06);
  transition: transform 120ms ease;
}

.product-card--sold {
  border-color: #e1e5e3;
}

.product-card--pressed {
  transform: scale(0.988);
}

.product-cover {
  position: relative;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f6ef;
}

.product-cover--blue {
  background: #e7f0fb;
}

.product-cover--sand {
  background: #f4eee2;
}

.product-cover--rose {
  background: #f8e9eb;
}

.product-cover--lime {
  background: #edf5df;
}

.product-cover--violet {
  background: #eeeafa;
}

.product-cover--cyan {
  background: #e4f4f3;
}

.product-cover--orange {
  background: #faeddf;
}

.product-cover--indigo {
  background: #e8eafa;
}

.product-cover--amber {
  background: #f8f0da;
}

.product-cover--coral {
  background: #f8e8e2;
}

.product-cover--sage {
  background: #e8f0e6;
}

.product-cover--slate {
  background: #e8edf0;
}

.product-cover__image {
  width: 100%;
  height: 100%;
}

.product-cover__label {
  color: rgba(28, 74, 53, 0.55);
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
}

.status-badge,
.condition-badge {
  position: absolute;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 650;
}

.status-badge {
  top: 18rpx;
  right: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #15865b;
}

.status-badge--reserved {
  background: rgba(255, 247, 226, 0.94);
  color: #b97513;
}

.status-badge--sold {
  background: rgba(238, 241, 239, 0.94);
  color: #68736d;
}

.condition-badge {
  top: 18rpx;
  left: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #3b5147;
  font-weight: 500;
}

.product-content {
  padding: 24rpx;
}

.product-title {
  display: -webkit-box;
  overflow: hidden;
  color: #1e2a24;
  font-size: 31rpx;
  font-weight: 650;
  line-height: 1.45;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.product-card--sold .product-title {
  color: #707a75;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  min-height: 44rpx;
  margin-top: 16rpx;
  overflow: visible;
}

.tag-item {
  min-height: 44rpx;
  display: inline-flex;
  align-items: center;
  box-sizing: border-box;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  background: #f1f5f3;
  color: #68736d;
  font-size: 21rpx;
  line-height: 1.4;
}

.product-meta,
.seller-row,
.price-row {
  display: flex;
  align-items: center;
}

.product-meta {
  justify-content: space-between;
  margin-top: 18rpx;
  color: #89938e;
  font-size: 22rpx;
}

.location-text {
  max-width: 68%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seller-row {
  margin-top: 18rpx;
}

.seller-avatar {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 14rpx;
  background: #e3f3eb;
  color: #16865c;
  font-size: 20rpx;
  font-weight: 700;
}

.seller-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  margin-left: 12rpx;
  color: #65716b;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meet-text {
  margin-left: 16rpx;
  color: #16a36a;
  font-size: 21rpx;
  font-weight: 600;
}

.price-row {
  justify-content: space-between;
  min-height: 54rpx;
  margin-top: 20rpx;
}

.price-group {
  min-width: 0;
  display: flex;
  align-items: baseline;
  flex: 1;
}

.price-value {
  color: #ef5d42;
  font-size: 38rpx;
  font-weight: 750;
  white-space: nowrap;
}

.price-value--free {
  color: #16a36a;
  font-size: 31rpx;
}

.original-price {
  margin-left: 10rpx;
  color: #a0a8a4;
  font-size: 21rpx;
  text-decoration: line-through;
  white-space: nowrap;
}

.view-count {
  margin-left: 16rpx;
  color: #a0a8a4;
  font-size: 20rpx;
  white-space: nowrap;
}
