.tabs-scroll {
  width: 100%;
  white-space: nowrap;
}

.tabs-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 2rpx 2rpx 6rpx;
}

.tab-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 60rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e2e9e5;
  border-radius: 999rpx;
  background: #ffffff;
  color: #68736d;
  font-size: 25rpx;
}

.tab-chip--active {
  border-color: #16a36a;
  background: #16a36a;
  color: #ffffff;
  font-weight: 600;
}
